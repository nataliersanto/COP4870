<?xml version="1.0" encoding="utf-8" ?>
<Shell
    x:Class="Maui.PoS.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Maui.PoS"
    xmlns:views="clr-namespace:Maui.PoS.Views"
    Shell.FlyoutBehavior="Disabled">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />
    
    <ShellContent
        Title="Course List"
        ContentTemplate="{DataTemplate views:CourseListView}"
        Route="CourseList" />

    <ShellContent
        Title="Teacher Menu"
        ContentTemplate="{DataTemplate views:TeacherMenuView}"
        Route="TeacherMenu" />

    <ShellContent
        Title="Student Menu"
        ContentTemplate="{DataTemplate views:StudentMenuView}"
        Route="StudentMenu" />

    <ShellContent
        Title="Course Detail"
        ContentTemplate="{DataTemplate views:CourseDetailView}"
        Route="CourseDetail" />

</Shell>