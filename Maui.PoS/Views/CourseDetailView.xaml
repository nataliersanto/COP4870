<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.PoS.Views.CourseDetailView"
             Title="Course Detail">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label x:Name="CourseNameLabel"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <Label x:Name="GradeLabel"
                   FontSize="20"
                   HorizontalOptions="Center"
                   TextColor="Green"/>

            <!-- Modules Section -->
            <Label Text="Modules"
                   FontSize="18"
                   FontAttributes="Bold"/>

            <ListView x:Name="ModulesListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextCell Text="{Binding Name}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Assignments Section -->
            <Label Text="Assignments"
                   FontSize="18"
                   FontAttributes="Bold"/>

            <ListView x:Name="AssignmentsListView"
                      ItemSelected="AssignmentSelected">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextCell Text="{Binding Name}"
                                  Detail="{Binding DueDate}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Roster Section -->
            <Label Text="Roster"
                   FontSize="18"
                   FontAttributes="Bold"/>

            <ListView x:Name="RosterListView">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <TextCell Text="{Binding Name}"
                                  Detail="{Binding Classification}"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <Button Text="Back"
                    Clicked="BackClicked"
                    BackgroundColor="Gray"/>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>